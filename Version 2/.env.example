# Copy this file to .env for local use.
PORT=3001
HOST=0.0.0.0
# All runtime data is stored directly in this Version 2 working folder.
DATA_ROOT=.
# Hybrid mode: SQL stores login/core employee details and JSON stores employee activity data.
STORE_PROVIDER=hybrid
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin

# SQL connection for login and employee master data.
SQL_SERVER=localhost\\SQLEXPRESS
SQL_DATABASE=ScheduleTracker
SQL_USER=
SQL_PASSWORD=
SQL_PORT=1433
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERT=true
